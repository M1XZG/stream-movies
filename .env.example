# Stream Movies — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Host path to your movie files (mounted read-only into the container)
HOST_MEDIA_DIR=/path/to/your/movies

# Path to movie files (inside Docker, this is the mount point)
# MEDIA_DIR=/media

# Web UI port
# WEB_PORT=10090

# RTSP server port
# RTSP_PORT=8554

# RTSP stream path (default: "stream" → rtsp://host:8554/stream)
# STREAM_PATH=stream

# External RTSP URL shown in the web UI (leave empty to hide)
# RTSP_EXTERNAL_URL=rtsp://your-domain.com/stream

# Video encoding
# VIDEO_BITRATE=2500k
# MAX_BITRATE=3500k
# BUFFER_SIZE=3500k
# MAX_WIDTH=1920
# MAX_HEIGHT=1080
# ENCODE_PRESET=veryfast

# Audio encoding
# AUDIO_BITRATE=192k
# AUDIO_CHANNELS=2

# MediaMTX
# MANAGE_MEDIAMTX=true
# MEDIAMTX_PATH=/usr/local/bin/mediamtx
# MEDIAMTX_API_PORT=9997
# RTSP_PUBLISH_HOST=localhost

# FFmpeg / FFprobe paths
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
